\begin_inset CommandInset label
LatexCommand label
name "def:AxiomsForDeterminant"

\end_inset

Consider any function 
\begin_inset Formula $\det:\F^{n\times n}\to\F$
\end_inset

 (that we sometimes also denote by 
\begin_inset Formula $\left|\cdot\right|$
\end_inset

 where 
\begin_inset Formula $\F\in\{\R,\C\}$
\end_inset

 (real or complex).
 
\end_layout

\begin_deeper
\begin_layout Standard
We say that 
\begin_inset Formula $\det$
\end_inset

 is a 
\emph on
determinant
\emph default
 if it satisfies the following properties:
\end_layout

\begin_layout Enumerate

\emph on
Normalisation.

\emph default
 
\end_layout

\begin_deeper
\begin_layout Standard
We require that 
\begin_inset Formula $\det I=1$
\end_inset

.
\end_layout

\end_deeper
\begin_layout Enumerate

\emph on
Anti-symmetry.
 
\end_layout

\begin_deeper
\begin_layout Standard
Let 
\begin_inset Formula $A\in\F^{(n\times n)}$
\end_inset

 and 
\begin_inset Formula $A'$
\end_inset

 be the same as 
\begin_inset Formula $A$
\end_inset

 except two of its rows have been exchanged.
 
\end_layout

\begin_layout Standard
We require that 
\begin_inset Formula $\det(A)=\det(A')$
\end_inset

.
\end_layout

\end_deeper
\begin_layout Enumerate

\emph on
Linearity in each row.
\end_layout

\begin_deeper
\begin_layout Standard
Determinant is linear in each row separately.
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $A\in\F^{n\times n}$
\end_inset

 and denote by 
\begin_inset Formula $v_{j}$
\end_inset

 the 
\begin_inset Formula $j$
\end_inset

th row of 
\begin_inset Formula $A$
\end_inset

,
 i.e.
 
\begin_inset Formula 
\[
A=\left[\begin{array}{ccc}
\text{---} & v_{1} & \text{---}\\
 & \vdots\\
\text{---} & v_{n} & \text{---}
\end{array}\right].
\]

\end_inset

Define the notation 
\begin_inset Formula $\det(v_{1},v_{2},\dots v_{n}):=\det(A)$
\end_inset

.
 
\end_layout

\begin_layout Standard
We require that 
\begin_inset Formula 
\[
\det(v_{1},\dots,v_{k-1},\quad\underbrace{c_{1}v_{k}+c_{2}u_{k}}_{k\text{th row}},\quad v_{k+1},\dots v_{n})
\]

\end_inset


\begin_inset Formula 
\[
=
\]

\end_inset


\begin_inset Formula 
\begin{align*}
c_{1}\det(v_{1},\dots v_{k-1},\quad\underbrace{v_{k}}_{k\text{th row}},\quad v_{k+1},\dots v_{n}) & \quad+\\
c_{2}\det(v_{1},\dots v_{k-1},\quad\underbrace{u_{k}}_{k\text{th row}},\quad v_{k+1},\dots v_{n}) & .
\end{align*}

\end_inset


\end_layout

\end_deeper
\end_deeper
\begin_layout Standard
\begin_inset Branch commentary
inverted 0
status collapsed

\begin_layout Itemize
Let us quickly recall the formulae for the determinant
\end_layout

\begin_deeper
\begin_layout Itemize
that we learnt in high-school,
 for 
\begin_inset Formula $2\times2$
\end_inset

 and 
\begin_inset Formula $3\times3$
\end_inset

 determinants:
\begin_inset Formula 
\[
\left|\begin{array}{cc}
a & b\\
c & d
\end{array}\right|=ad-bc,
\]

\end_inset

and 
\begin_inset Formula 
\[
\left|\begin{array}{ccc}
a & b & c\\
d & e & f\\
g & h & i
\end{array}\right|=aei-afh+bfg-bdi+cdh-ceg.
\]

\end_inset

 
\end_layout

\end_deeper
\begin_layout Itemize
To ensure we have understood 
\begin_inset CommandInset ref
LatexCommand formatted
reference "def:AxiomsForDeterminant"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

,
 
\end_layout

\begin_deeper
\begin_layout Itemize
let us check that the three properties are satisfied 
\end_layout

\begin_deeper
\begin_layout Itemize
by our formula for the 
\begin_inset Formula $2\times2$
\end_inset

 and 
\begin_inset Formula $3\times3$
\end_inset

 case.
\end_layout

\end_deeper
\begin_layout Itemize
Normalisation:
\end_layout

\begin_deeper
\begin_layout Itemize
Clearly,
 
\begin_inset Formula $\left|\begin{array}{cc}
1\\
 & 1
\end{array}\right|=1$
\end_inset

 (set 
\begin_inset Formula $b=c=0$
\end_inset

,
 
\begin_inset Formula $ad$
\end_inset

 survives).
\end_layout

\begin_layout Itemize
Similarly,
 
\begin_inset Formula $\left|\begin{array}{ccc}
1\\
 & 1\\
 &  & 1
\end{array}\right|=1$
\end_inset

 (set 
\begin_inset Formula $b=c=d=f=g=h=0$
\end_inset

;
 only the 
\begin_inset Formula $aei$
\end_inset

 term survives).
\end_layout

\end_deeper
\begin_layout Itemize
Antisymmetry:
 
\end_layout

\begin_deeper
\begin_layout Itemize
Clearly,
 
\begin_inset Formula $\begin{vmatrix}1\\
 & 1
\end{vmatrix}=1$
\end_inset

 but 
\begin_inset Formula $\begin{vmatrix} & 1\\
1
\end{vmatrix}=-1$
\end_inset

 (only 
\begin_inset Formula $-bc$
\end_inset

 survives).
\end_layout

\begin_layout Itemize
Again,
 
\begin_inset Formula $\left|\begin{array}{ccc}
1\\
 & 1\\
 &  & 1
\end{array}\right|=1$
\end_inset

 but 
\begin_inset Formula $\left|\begin{array}{ccc}
1\\
 &  & 1\\
1
\end{array}\right|=1\cdot(-1)=-1$
\end_inset

.
\end_layout

\end_deeper
\begin_layout Itemize
Linearity in each row:
\end_layout

\begin_deeper
\begin_layout Itemize
We leave this as a small exercise to verify that 
\begin_inset Formula 
\[
\left|\begin{array}{cc}
a+a' & b+b'\\
c & d
\end{array}\right|\overset{\text{exercise}}{=}\left|\begin{array}{cc}
a & b\\
c & d
\end{array}\right|+\left|\begin{array}{cc}
a' & b'\\
c & d
\end{array}\right|.
\]

\end_inset


\end_layout

\begin_layout Itemize
This is immediate
\begin_inset Formula 
\[
\left|\begin{array}{cc}
ta & tb\\
c & d
\end{array}\right|=t\left|\begin{array}{cc}
a & b\\
c & d
\end{array}\right|.
\]

\end_inset


\end_layout

\end_deeper
\end_deeper
\end_inset


\end_layout

\begin_layout Itemize
It is worth pointing out that,
 in general,
 
\begin_inset Formula 
\[
\det(A+B)\neq\det(A)+\det(B)
\]

\end_inset

 and similarly,
 in general,
 
\begin_inset Formula 
\[
\det(tA)\neq t\det(A).
\]

\end_inset


\end_layout

\begin_layout Itemize
In fact,
 it turns out that if 
\begin_inset Formula $A$
\end_inset

 is an 
\begin_inset Formula $n\times n$
\end_inset

 matrix,
 then 
\begin_inset Formula 
\[
\det(tA)=t^{n}\det(A).
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Branch commentary
inverted 0
