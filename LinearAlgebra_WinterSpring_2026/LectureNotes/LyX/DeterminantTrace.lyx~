\begin_inset Formula $\det(A^{T})=\det(A)$
\end_inset

 where 
\begin_inset Formula $A^{T}$
\end_inset

 is the transpose of 
\begin_inset Formula $A$
\end_inset

,
 i.e.
 
\begin_inset Formula $(A^{T})_{ij}=(A)_{ji}$
\end_inset

 for all 
\begin_inset Formula $i,j$
\end_inset

.
 
\end_layout

\begin_layout Solution*
Let 
\begin_inset Formula $B=A^{T}$
\end_inset

.
 This means that 
\begin_inset Formula $b_{ij}=a_{ji}$
\end_inset

 for all 
\begin_inset Formula $i$
\end_inset

 (we are using 
\begin_inset Formula $b_{ij}$
\end_inset

 and 
\begin_inset Formula $a_{ij}$
\end_inset

 to denote the 
\begin_inset Formula $i$
\end_inset

th row and 
\begin_inset Formula $j$
\end_inset

th column of 
\begin_inset Formula $B$
\end_inset

 and 
\begin_inset Formula $A$
\end_inset

 respectively).
 Note 
\begin_inset Formula 
\begin{align*}
\det A^{T}=\det B= & \sum_{\sigma\in S_{n}}b_{1\sigma(1)}b_{2\sigma(2)}\cdots b_{n\sigma(n)}\sign(\sigma)\\
= & \sum_{\sigma\in S_{n}}a_{\sigma(1)1}a_{\sigma(2)2}\cdots a_{\sigma(n)n}\sign(\sigma)\\
= & \sum_{\sigma\in S_{n}}a_{1\sigma^{-1}(1)}a_{2\sigma^{-1}(2)}\cdots a_{n\sigma^{-1}(n)}\sign(\sigma)\\
= & \sum_{\pi\in S_{n}}a_{1\pi(1)}a_{2\pi(2)}\cdots a_{n\pi(n)}\sign(\pi^{-1}) & \text{take }\pi=\sigma^{-1}\\
= & \sum_{\pi\in S_{n}}a_{1\pi(1)}a_{2\pi(2)}\cdots a_{n\pi(n)}\sign(\pi) & \because\sign(\pi)=\sign(\pi^{-1})\\
= & \det A.
\end{align*}

\end_inset


\end_layout

\begin_layout Proposition
It holds that 
\begin_inset Formula $\det(AB)=\det A\cdot\det B$
\end_inset

 if 
\begin_inset Formula $\det A\neq0$
\end_inset

 or 
\begin_inset Formula $\det B\neq0$
\end_inset

.
 
\end_layout

\begin_layout Proof
Proceed as follows.
\end_layout

\begin_deeper
\begin_layout Itemize
