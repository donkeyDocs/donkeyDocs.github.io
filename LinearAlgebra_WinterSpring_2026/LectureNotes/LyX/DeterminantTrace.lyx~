\begin_inset Formula $d$
\end_inset

 as a function of 
\begin_inset Formula $A$
\end_inset

 (keep 
\begin_inset Formula $B$
\end_inset

 fixed).
\end_layout

\begin_layout Itemize
Claim (left as an exercise).
 
\begin_inset Formula $d(A)$
\end_inset

 satisfies the axioms in 
\begin_inset CommandInset ref
LatexCommand formatted
reference "def:AxiomsForDeterminant"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 (i.e.
 
\begin_inset Formula $d(I)=1$
\end_inset

,
 anti-symmetry and linearity in any row).
 
\end_layout

\begin_layout Itemize
We already showed (in 
\begin_inset CommandInset ref
LatexCommand formatted
reference "thm:generalDet"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

