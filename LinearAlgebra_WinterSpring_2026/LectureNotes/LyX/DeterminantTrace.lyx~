\begin_layout Theorem
\begin_inset CommandInset label
LatexCommand label
name "thm:generalDet"

\end_inset

Let 
\begin_inset Formula $\det$
\end_inset

 be any function satisfying 
\begin_inset CommandInset ref
LatexCommand formatted
reference "def:AxiomsForDeterminant"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

.
 Let 
\begin_inset Formula $A\in\F^{n\times n}$
\end_inset

.
 Then 
\begin_inset Formula $\det(A)$
\end_inset

 is uniquely specified by 
\begin_inset Formula 
\[
\det(A)=\sum_{\sigma\in S_{n}}a_{1\sigma(1)}a_{2\sigma(2)}\cdots a_{n\sigma(n)}\sign(\sigma)
\]

\end_inset

where 
\begin_inset Formula $S_{n}$
\end_inset

 is the set of all permutations on 
\begin_inset Formula $n$
\end_inset

 elements.
\end_layout

\begin_layout Standard
\begin_inset Branch proof
inverted 0
status collapsed

\begin_layout Proof
The strategy again is to 
\end_layout

\begin_deeper
\begin_layout Itemize
decompose each row such that it has only one non-zero column vector,
 
\end_layout

\begin_deeper
\begin_layout Itemize
by invoking Axiom 3 repeatedly,
 and
\end_layout

\end_deeper
\begin_layout Itemize
argue that all but 
\begin_inset Formula $n!$
\end_inset

 terms yield 
\begin_inset Formula $0$
\end_inset

 
\end_layout

\begin_deeper
\begin_layout Itemize
by using the various properties of the determinant we proved (primarily Property 1).
\end_layout

\end_deeper
\begin_layout Standard
Denote by 
\begin_inset Formula $a_{ij}$
\end_inset

 the 
\begin_inset Formula $i$
\end_inset

th row and 
\begin_inset Formula $j$
\end_inset

th column of 
\begin_inset Formula 
\[
A=\left[\begin{array}{ccc}
\text{---} & v_{1} & \text{---}\\
 & \vdots\\
\text{---} & v_{n} & \text{---}
\end{array}\right].
\]

\end_inset

One can write 
\begin_inset Formula 
\begin{align*}
v_{i} & =(a_{i1},\dots a_{in})\\
 & =\sum^{n}_{j=1}a_{ij}e_{j}
\end{align*}

\end_inset

where 
\begin_inset Formula $e_{1},\dots e_{n}$
\end_inset

 is the standard basis.
 Now,
 one can further write 
\begin_inset Formula 
\begin{align*}
\det A & =\det(v_{1},v_{2}\dots v_{n})\\
 & =\det\left(\sum^{n}_{j=1}a_{1j}e_{j},v_{2},\dots v_{n}\right)\\
 & =\sum^{n}_{j=1}a_{1j}\det\left(e_{j},v_{2},\dots v_{n}\right) & \text{Axiom 3}\\
 & =\sum^{n}_{j_{1}=1}\sum^{n}_{j_{2}=1}a_{1j_{1}}a_{2j_{2}}\det(e_{j_{1}},e_{j_{2}},v_{3},\dots v_{n}) & \text{Axiom 3}\\
 & =\sum^{n}_{j_{1}=1}\sum^{n}_{j_{2}=1}\cdots\sum^{n}_{j_{n}=1}a_{1j_{1}}a_{2j_{2}}\dots j_{nj_{n}}\det(e_{j_{1}},\dots e_{j_{n}}) & \text{Axiom 3}.
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
Note that this sum contains 
\begin_inset Formula 
\[
\underbrace{n\cdot n\cdot\cdots n}_{n\text{- many}}=n^{n}
\]

\end_inset

 terms but most of these are zero.
\end_layout

\begin_deeper
\begin_layout Itemize
Concretely,
 if any two of the indices 
\begin_inset Formula $j_{1},\dots j_{n}$
\end_inset

 coincide,
 then 
\begin_inset Formula $\det(e_{j_{1}},\dots e_{j_{n}})=0$
\end_inset

 (by Property 1).
 
\end_layout

\begin_layout Itemize
Consequently,
 the sum can be simplified as follows 
\begin_inset Formula 
\begin{equation}
\det A=\sum_{\sigma\in S_{n}}a_{1\sigma(1)}a_{2\sigma(2)}\cdots a_{n\sigma(n)}\det(e_{1\sigma(1)},\cdots,e_{n\sigma(n)})\label{eq:secondLast}
\end{equation}

\end_inset

where 
\begin_inset Formula $S_{n}$
\end_inset

 is the set of all permutations on 
\begin_inset Formula $\{1,2\dots,n\}$
\end_inset

 and 
\begin_inset Formula $|S_{n}|=n!$
\end_inset

.
 
\end_layout

\end_deeper
\begin_layout Itemize
Note also that 
\begin_inset Formula 
\begin{equation}
\det(e_{1\sigma(1)},\dots e_{n\sigma(n)})=\sign(\sigma)\label{eq:last}
\end{equation}

\end_inset

using Axiom 2 and Axiom 1.
\end_layout

\begin_layout Standard
Combining 
\begin_inset CommandInset ref
LatexCommand formatted
reference "eq:secondLast,eq:last"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

,
 we get the desired expression.
 
\end_layout

\end_deeper
\end_inset


\end_layout

