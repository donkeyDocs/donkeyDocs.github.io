\begin_layout Solution*
We have 
\begin_inset Formula 
\begin{align}
\left|\begin{array}{cc}
a & b\\
c & d
\end{array}\right| & =\left|\begin{array}{cc}
a & 0\\
c & d
\end{array}\right|+\left|\begin{array}{cc}
0 & b\\
c & d
\end{array}\right| & \text{Using Axiom 3 on row 1}\nonumber \\
 & =\underbrace{\left|\begin{array}{cc}
a & 0\\
c & 0
\end{array}\right|+\left|\begin{array}{cc}
a & 0\\
0 & d
\end{array}\right|}_{\text{\text{Using Axiom 3 on row 2}}}+\left|\begin{array}{cc}
0 & b\\
c & d
\end{array}\right|\nonumber \\
 & =\left|\begin{array}{cc}
a & 0\\
c & 0
\end{array}\right|+\left|\begin{array}{cc}
a & 0\\
0 & d
\end{array}\right|+\underbrace{\left|\begin{array}{cc}
0 & b\\
c & 0
\end{array}\right|+\left|\begin{array}{cc}
0 & b\\
0 & d
\end{array}\right|}_{\text{Using Axiom 3 on row 2}}\nonumber \\
 & =\underbrace{\left|\begin{array}{cc}
a & 0\\
0 & 0
\end{array}\right|}_{\text{subtracting \ensuremath{ca^{-1}} row 1 from row 2}}+\left|\begin{array}{cc}
a & 0\\
0 & d
\end{array}\right| & \text{Using Property 4}\nonumber \\
 & +\left|\begin{array}{cc}
0 & b\\
c & 0
\end{array}\right|+\underbrace{\left|\begin{array}{cc}
0 & b\\
0 & 0
\end{array}\right|}_{\text{subtracting \ensuremath{db^{-1}} row 1 from row 2}}\label{eq:expansion}\\
 & =\left|\begin{array}{cc}
a & 0\\
0 & d
\end{array}\right|+\left|\begin{array}{cc}
0 & b\\
c & 0
\end{array}\right| & \text{Using Property 2}\nonumber \\
 & =ad-\left|\begin{array}{cc}
b & 0\\
0 & c
\end{array}\right| & \text{Using Property 5 and Axiom 2}\nonumber \\
 & =ad-bc.\nonumber 
\end{align}

