\begin_layout Subsection
Relation with eigenvalues
\end_layout

\begin_layout Standard
\begin_inset Branch commentary
inverted 0
status collapsed

\begin_layout Standard
To state the next lemma,
 we recall that
\end_layout

\begin_layout Itemize
\begin_inset Formula $\lambda$
\end_inset

 is an eigenvalue of an 
\begin_inset Formula $n\times n$
\end_inset

 matrix 
\begin_inset Formula $A$
\end_inset

 if 
\begin_inset Formula 
\[
Ax=\lambda x,\quad\forall x\in\F^{n},x\neq0
\]

\end_inset

and 
\begin_inset Formula $\F\in\{\R,\C\}$
\end_inset

.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\lambda$
\end_inset

 is an eigenvalue of an operator 
\begin_inset Formula $T$
\end_inset

 if there is a non-zero 
\begin_inset Formula $x$
\end_inset

 such that 
\begin_inset Formula $Tx=\lambda x$
\end_inset

.
\end_layout

\end_inset


\end_layout

\begin_layout Lemma
\begin_inset Formula $\lambda$
\end_inset

 is an eigenvalue of a matrix 
\begin_inset Formula $A$
\end_inset

 if and only if 
\begin_inset Formula $\det(A-\lambda I)=0$
\end_inset

.
\end_layout

\begin_layout Proof
Note that for an 
\begin_inset Formula $x\neq0$
\end_inset

,
\begin_inset Formula 
\begin{align*}
 & Ax=\lambda x\\
\iff & (A-\lambda I)x=0,\\
\iff & (A-\lambda I) & \text{is not invertible}.
\end{align*}

\end_inset

Using 
\begin_inset CommandInset ref
LatexCommand formatted
reference "lem:detInvert"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 we have that 
\begin_inset Formula $A'$
\end_inset

 is invertible if and only if 
\begin_inset Formula $\det A'\neq0$
\end_inset

.
 Setting 
\begin_inset Formula $A'=(A-\lambda I)$
\end_inset

,
 we obtain the result.
\end_layout

\begin_layout Remark
\begin_inset CommandInset label
LatexCommand label
name "rem:RootsOfDet(A-lambdaI)"

\end_inset

For an 
\begin_inset Formula $n\times n$
\end_inset

 matrix 
\begin_inset Formula $A$
\end_inset

,
 the roots of 
\begin_inset Formula $\det(A-\lambda I)=0$
\end_inset

 gives the eigenvalues of 
\begin_inset Formula $A$
\end_inset

.
 These are the 
\begin_inset Formula $n$
\end_inset

 eigenvalues counting multiplicities of the roots.
 
\end_layout

\begin_layout Standard
We are almost done.
 Let us look at how the trace and determinant relate to eigenvalues of a matrix.
 
\end_layout

\begin_layout Theorem
\begin_inset CommandInset label
LatexCommand label
name "thm:det_tr_prod_sum"

\end_inset

Let 
\begin_inset Formula $A$
\end_inset

 be an 
\begin_inset Formula $n\times n$
\end_inset

 matrix over complex numbers 
\begin_inset Formula $\C$
\end_inset

 and let 
\begin_inset Formula $\lambda_{1},\dots\lambda_{n}$
\end_inset

 be its eigenvalues (counting multiplicities).
 Then,
 
\begin_inset Formula $\tr(A)=\sum^{n}_{i=1}\lambda_{i}$
\end_inset

 and 
\begin_inset Formula $\det A=\prod^{n}_{i=1}\lambda_{i}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Branch proof
inverted 0
status collapsed

\begin_layout Proof
We start with 
\begin_inset Formula $\det A$
\end_inset

.
 We have 
\begin_inset Formula 
\[
\det(A-\lambda I)=\prod^{n}_{i=1}(\lambda_{i}-\lambda)
\]

\end_inset

from 
\begin_inset CommandInset ref
LatexCommand formatted
reference "rem:RootsOfDet(A-lambdaI)"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 for any 
\begin_inset Formula $\lambda\in\C$
\end_inset

.
 Setting 
\begin_inset Formula $\lambda=0$
\end_inset

,
 we obtain 
\begin_inset Formula $\det A=\prod^{n}_{i=1}\lambda_{i}$
\end_inset

.
 
\end_layout

\begin_layout Proof
Let us now look at 
\begin_inset Formula $\tr(A)$
\end_inset

.
 The idea here is to look at 
\begin_inset Formula $\det(A-\lambda I)$
\end_inset

 as a polynomial in 
\begin_inset Formula $\lambda$
\end_inset

 but in two different ways and then equating the appropriate coefficient of 
\begin_inset Formula $\lambda^{n-1}$
\end_inset

.
\end_layout

\begin_deeper
\begin_layout Itemize
Observe that the coefficient of 
\begin_inset Formula $\lambda^{n-1}$
\end_inset

 in 
\begin_inset Formula $\det(A-\lambda I)=(\lambda_{1}-\lambda)\cdots(\lambda_{n}-\lambda)$
\end_inset

 is 
\begin_inset Formula 
\begin{equation}
\mathsf{coeff}:=(-1)^{n-1}(\lambda_{1}+\cdots+\lambda_{n}).\label{eq:sum}
\end{equation}

\end_inset

 
\end_layout

\begin_layout Itemize
Also,
 observe that 
\begin_inset Formula 
\[
\det(A-\lambda I)=\sum^{n}_{i=1}(a_{ii}-\lambda)+q(\lambda)
\]

\end_inset

 where 
\begin_inset Formula $q(\lambda)$
\end_inset

 is a polynomial of degree at most 
\begin_inset Formula $n-2$
\end_inset

 (in 
\begin_inset Formula $\lambda$
\end_inset

).
 
\end_layout

\begin_deeper
\begin_layout Itemize
This is easily seen from the formula of 
\begin_inset Formula $\det$
\end_inset

 in 
\begin_inset CommandInset ref
LatexCommand formatted
reference "thm:generalDet"
plural "false"
caps "true"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 and 
\end_layout

\begin_layout Itemize
noting that the remaining terms will have at least two terms that are not along the diagonal.
\end_layout

\begin_layout Itemize
Therefore,
 the coefficient of 
\begin_inset Formula $\lambda^{n-1}$
\end_inset

 in 
\begin_inset Formula $\det(A-\lambda I)$
\end_inset

 must come from 
\end_layout

\begin_deeper
\begin_layout Itemize
the coefficient of 
\begin_inset Formula $\lambda^{n-1}$
\end_inset

 
\begin_inset Formula $\sum^{n}_{i=1}(a_{ii}-\lambda)$
\end_inset

,
\end_layout

\begin_layout Itemize
which in turn is
\begin_inset Formula 
\[
\mathsf{coeff}':=(-1)^{n-1}(a_{11}+\cdots+a_{nn})=(-1)^{n-1}\tr(A).
\]

\end_inset


\end_layout

\end_deeper
\end_deeper
\begin_layout Itemize
Clearly,
 
\begin_inset Formula $\mathsf{coeff}$
\end_inset

 and 
\begin_inset Formula $\mathsf{coeff'}$
\end_inset

 are the same quantity,
 evaluated differently.
 Equating them,
 we get 
\begin_inset Formula 
\[
\tr(A)=(\lambda_{1}+\cdots+\lambda_{n})
\]

\end_inset

as asserted.
 
\end_layout

\end_deeper
\end_inset


\end_layout

